# kimi-tachi Hooks 配置示例 (v0.5.2+)
#
# 使用方法:
# 1. 复制此文件到 ~/.kimi/config.toml (或合并到现有配置)
# 2. 修改路径为实际安装路径
# 3. 重启 kimi-cli 生效

# ============================================
# 自动记忆管理 Hooks (v0.5.2+)
# ============================================

# 1. 会话开始时自动回忆上下文
# 功能: 恢复之前的会话状态、显示未完成的 todo
[[hooks]]
event = "SessionStart"
command = "/home/lee/.kimi/agents/kimi-tachi/hooks/recall-on-start.sh"
timeout = 10

# 2. 上下文压缩前自动存储关键决策 (⭐ 核心功能)
# 功能: 在上下文被压缩前，提取并存储重要决策到记忆
[[hooks]]
event = "PreCompact"
command = "/home/lee/.kimi/agents/kimi-tachi/hooks/store-before-compact.sh"
timeout = 10

# 3. 会话结束时自动生成总结
# 功能: 总结会话内容、归档会话数据
[[hooks]]
event = "SessionEnd"
command = "/home/lee/.kimi/agents/kimi-tachi/hooks/summarize-on-end.sh"
timeout = 15

# 4. Agent 调用后自动记录决策
# 功能: 记录 Agent 调用、提取关键决策
[[hooks]]
event = "PostToolUse"
matcher = "Agent"
command = "/home/lee/.kimi/agents/kimi-tachi/hooks/process-agent.sh"
timeout = 5

# ============================================
# 追踪与监控 Hooks
# ============================================

# 子代理启动/停止追踪
[[hooks]]
event = "SubagentStart"
command = "/home/lee/.kimi/agents/kimi-tachi/hooks/trace-agent.sh"
timeout = 5

[[hooks]]
event = "SubagentStop"
command = "/home/lee/.kimi/agents/kimi-tachi/hooks/trace-agent.sh"
timeout = 5

# ============================================
# 辅助功能 Hooks
# ============================================

# 回合结束时检查未完成的 todo
[[hooks]]
event = "Stop"
command = "/home/lee/.kimi/agents/kimi-tachi/hooks/check-todos.sh"
timeout = 5

# 阻止直接修改敏感文件
[[hooks]]
event = "PreToolUse"
matcher = "WriteFile|StrReplaceFile"
command = "/home/lee/.kimi/agents/kimi-tachi/hooks/protect-sensitive.sh"
timeout = 5

# ============================================
# 可选: 代码格式化 (PostToolUse)
# ============================================
# [[hooks]]
# event = "PostToolUse"
# matcher = "WriteFile|StrReplaceFile"
