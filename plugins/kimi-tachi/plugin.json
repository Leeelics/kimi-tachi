{
  "name": "kimi-tachi",
  "version": "0.4.1",
  "description": "Kimi-tachi multi-agent orchestration plugin - run workflows and manage sessions",
  "tools": [
    {
      "name": "workflow",
      "description": "Run a multi-agent workflow for a task (feature, bugfix, explore, refactor, quick)",
      "command": ["python3", "scripts/workflow.py"],
      "parameters": {
        "type": "object",
        "properties": {
          "task": {
            "type": "string",
            "description": "Task description to execute"
          },
          "workflow_type": {
            "type": "string",
            "enum": ["auto", "feature", "bugfix", "explore", "refactor", "quick"],
            "default": "auto",
            "description": "Type of workflow to run"
          },
          "work_dir": {
            "type": "string",
            "default": ".",
            "description": "Working directory for the task"
          }
        },
        "required": ["task"]
      }
    },
    {
      "name": "list_agents",
      "description": "List all available kimi-tachi agents (七人衆) with their roles and icons",
      "command": ["python3", "scripts/list_agents.py"],
      "parameters": {
        "type": "object",
        "properties": {},
        "required": []
      }
    },
    {
      "name": "get_agent_info",
      "description": "Get detailed information about a specific agent",
      "command": ["python3", "scripts/agent_info.py"],
      "parameters": {
        "type": "object",
        "properties": {
          "agent": {
            "type": "string",
            "enum": ["kamaji", "shishigami", "nekobasu", "calcifer", "enma", "tasogare", "phoenix"],
            "description": "Agent name to get info for"
          }
        },
        "required": ["agent"]
      }
    },
    {
      "name": "check_compatibility",
      "description": "Check kimi-cli version compatibility with kimi-tachi",
      "command": ["python3", "scripts/check_compatibility.py"],
      "parameters": {
        "type": "object",
        "properties": {},
        "required": []
      }
    },
    {
      "name": "get_session_status",
      "description": "Get current kimi-tachi session status including active agents and tasks",
      "command": ["python3", "scripts/session_status.py"],
      "parameters": {
        "type": "object",
        "properties": {
          "session_id": {
            "type": "string",
            "description": "Optional session ID to check"
          }
        },
        "required": []
      }
    },
    {
      "name": "list_background_tasks",
      "description": "List active and recent background tasks",
      "command": ["python3", "scripts/list_tasks.py"],
      "parameters": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": ["all", "active", "completed", "failed"],
            "default": "all",
            "description": "Filter tasks by status"
          }
        },
        "required": []
      }
    }
  ]
}
