{
  "name": "kimi-tachi",
  "version": "0.3.0",
  "description": "Kimi-tachi multi-agent orchestration plugin - run workflows and manage sessions",
  "config_file": "config.json",
  "inject": {
    "KIMI_API_KEY": "api_key",
    "KIMI_BASE_URL": "base_url"
  },
  "tools": [
    {
      "name": "workflow",
      "description": "Run a multi-agent workflow for a task (feature, bugfix, explore, refactor, quick)",
      "command": ["python3", "scripts/workflow.py"],
      "parameters": {
        "type": "object",
        "properties": {
          "task": {
            "type": "string",
            "description": "Task description to execute"
          },
          "workflow_type": {
            "type": "string",
            "enum": ["auto", "feature", "bugfix", "explore", "refactor", "quick"],
            "default": "auto",
            "description": "Type of workflow to run"
          },
          "work_dir": {
            "type": "string",
            "default": ".",
            "description": "Working directory for the task"
          }
        },
        "required": ["task"]
      }
    },
    {
      "name": "list_agents",
      "description": "List all available kimi-tachi agents (七人衆) with their roles and icons",
      "command": ["python3", "scripts/list_agents.py"],
      "parameters": {
        "type": "object",
        "properties": {},
        "required": []
      }
    },
    {
      "name": "get_agent_info",
      "description": "Get detailed information about a specific agent",
      "command": ["python3", "scripts/agent_info.py"],
      "parameters": {
        "type": "object",
        "properties": {
          "agent": {
            "type": "string",
            "enum": ["kamaji", "shishigami", "nekobasu", "calcifer", "enma", "tasogare", "phoenix"],
            "description": "Agent name to get info for"
          }
        },
        "required": ["agent"]
      }
    },
    {
      "name": "check_compatibility",
      "description": "Check kimi-cli version compatibility with kimi-tachi",
      "command": ["python3", "scripts/check_compatibility.py"],
      "parameters": {
        "type": "object",
        "properties": {},
        "required": []
      }
    }
  ]
}
